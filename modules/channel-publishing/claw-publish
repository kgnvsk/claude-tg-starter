#!/bin/bash
# claw-publish <html-file> — publish an HTML post to the configured channel.
# Deterministic: always the channel, always parse_mode=HTML. Never the user DM.
set -eu
[ -z "${1:-}" ] && { echo "usage: claw-publish <html-file>"; exit 1; }
[ -f ~/.claude/channels/telegram/.env ] && export $(grep -v "^#" ~/.claude/channels/telegram/.env | xargs)
CHANNEL="{{CHANNEL_ID}}"   # the ONLY publish target (owner's channel id)
TEXT=$(cat "$1")
curl -s -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
  --data-urlencode "chat_id=${CHANNEL}" \
  --data-urlencode "parse_mode=HTML" \
  --data-urlencode "disable_web_page_preview=true" \
  --data-urlencode "text=${TEXT}" \
  | python3 -c "import sys,json; d=json.load(sys.stdin); print(\"published to channel\" if d.get(\"ok\") else d)"
