# agent.env — single source of all owner inputs for a Cash deploy.
#
# Copy to agent.env, fill it in, then source it before running install-core:
#   cp assets/templates/agent.env.example agent.env
#   # ...edit agent.env...
#   set -a; . ./agent.env; set +a
#   bash assets/install-core.sh
#
# install-core reads these from the environment, renders every {{PLACEHOLDER}},
# writes ~/.claude/channels/telegram/.env (chmod 600), and installs the crontab.
# NEVER commit a filled-in agent.env — it holds the bot token (it's .gitignored).

# ─────────────────────────── REQUIRED ───────────────────────────
AGENT_NAME=                 # имя АГЕНТА (как бот себя зовёт), напр. BroAgent. НЕ «Cash» — это чужое имя. Если владелец не определился — спроси его.
OWNER_NAME=                 # имя владельца для персоны, напр. Alex
OWNER_TG_USERNAME=          # его @username в Telegram, БЕЗ @
OWNER_CHAT_ID=              # его user_id (узнать: @userinfobot) — allowlist + алерты
BOT_USERNAME=               # username бота, БЕЗ @ (оканчивается на _bot)
TIMEZONE=                   # IANA TZ, напр. Europe/Lisbon — для кронов
TELEGRAM_BOT_TOKEN=         # от @BotFather, вида 1234567890:AA...  (СЕКРЕТ)

# ─────────────────────────── OPTIONAL ───────────────────────────
OPENAI_API_KEY=             # голосовые (transcribe). Пусто → транскрипция выключена.
CALENDAR_EMAIL=             # утренний дайджест 07:30 через gcalcli. Пусто → крон не ставится.
OWNER_EMAIL=                # email владельца. Нужен для веб-vault: Vercel требует, чтобы автор
                            #   коммита совпадал с email аккаунта (иначе деплой = COMMIT_AUTHOR_REQUIRED).
                            #   Тот же email — для GitHub. Пусто → setup.sh пропустит git-author и предупредит.
VAULT_LOCALE=en-US          # локаль Quartz для веб-vault (en-US, uk-UA, ru-RU…). Влияет на формат дат.

# ──────────────────── OPT-IN MODULES (flags) ────────────────────
# Каждый модуль ставится install-core'ом ТОЛЬКО если флаг = 1.
# Базовый агент (бот, память, календарь, картинки, PDF, браузер) работает без них.

MODULE_DESIGN_PACK=0        # 1 → дизайн-скиллы (impeccable/frontend-design/apple-bento) + vercel-deploy.
                            #     Нужен node (Фаза 1) и токен Vercel (Фаза 6) для деплоев.
MODULE_CHANNEL_PUBLISH=0    # 1 → публикация постов в Telegram-канал (claw-publish) + (опц.) auto-publisher.
                            #     Требует CHANNEL_ID ниже.
MODULE_SOCIAL_BROWSER=0     # 1 → залогиненный браузер (Xvfb+Chrome+proxy) для Instagram/Threads.
                            #     Тяжёлый модуль; ставь только если реально нужен соц-постинг.
MODULE_TRANSPORT_DAEMON=0   # 1 → (экспериментально, v3) приём Telegram выносится в lingered systemd-user
                            #     демон — бот не глохнет при смерти claude-процесса. Дефолт 0 = проверенный
                            #     bot.start. Ставится отдельно: bash modules/transport-daemon/install.sh
                            #     (откат: тот же скрипт с аргументом `disable`).
MODULE_VAULT_WEB=0          # 1 → веб-вью Obsidian-vault на Vercel (Quartz: граф+заметки+поиск), за паролем.
                            #     Бренд уже зашит (Unbounded+Onest, амбер, граф под текстом). Ставится:
                            #     bash modules/vault-web/setup.sh <vercel-домен>. Если есть ~/.config/vercel-token
                            #     и SITE_PASSWORD — задеплоит сам; иначе подключаешь репо к Vercel вручную +
                            #     env SITE_PASSWORD. Нужен OWNER_EMAIL (git-author). См. modules/vault-web/README.

# ─────────── module params (нужны только при взведённом флаге) ───────────
CHANNEL_ID=                 # для MODULE_CHANNEL_PUBLISH: -100... id целевого канала (бот — админ канала)
SITE_PASSWORD=              # для MODULE_VAULT_WEB (опц.): пароль Basic-Auth для веб-vault. Если задан +
                            #   есть vercel-token, setup.sh выставит его в Vercel env сам. Пусто → ставишь в дашборде.
